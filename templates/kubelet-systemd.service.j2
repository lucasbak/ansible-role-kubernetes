[Unit]
Description=kubelet: The Kubernetes Node Agent
Documentation=https://kubernetes.io/docs/
Wants=network-online.target
After=network-online.target

[Service]
ExecStart=/usr/bin/kubelet --node-ip={{ hosts | selectattr('fqdn', 'equalto', inventory_hostname) | map(attribute='ip') | first }} --hostname-override={{ inventory_hostname }}
Restart=always
StartLimitInterval=0
RestartSec=10

[Install]
WantedBy=multi-user.target